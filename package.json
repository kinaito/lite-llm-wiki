{
  "name": "lite-llm-wiki",
  "version": "1.0.0",
  "description": "Obsidian知识卡片生成插件，基于LLM自动将Markdown文件转换为标准化知识卡片和实体页面",
  "main": "main.js",
  "scripts": {
    "dev": "rollup --config rollup.config.js -w",
    "build": "rollup --config rollup.config.js --environment BUILD:production"
  },
  "keywords": [
    "obsidian",
    "plugin",
    "knowledge-card",
    "llm",
    "wiki"
  ],
  "author": "树",
  "license": "MIT",
  "devDependencies": {
    "@rollup/plugin-commonjs": "^25.0.7",
    "@rollup/plugin-node-resolve": "^15.2.3",
    "@rollup/plugin-typescript": "^11.1.6",
    "@types/node": "^20.11.7",
    "obsidian": "latest",
    "rollup": "^4.9.6",
    "tslib": "^2.6.2",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "axios": "^1.6.7",
    "crypto-js": "^4.2.0"
  }
}